<Window x:Class="QRCodeGenerator.MainWindow" 

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 

        Title="二维码生成器" Height="450" Width="600" 

        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



     
        <GroupBox Grid.Row="0" Header="输入内容" Margin="0,0,0,10">

            <Grid Margin="10">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>



              

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">

                    <RadioButton x:Name="rbText" Content="文字/链接" IsChecked="True"  

                                 Margin="0,0,10,0" Checked="ContentType_Changed"/>

                    <RadioButton x:Name="rbImage" Content="图片"  

                                 Checked="ContentType_Changed"/>

                </StackPanel>



              

                <TextBox x:Name="txtInput" Grid.Row="1" Height="60"  

                         TextWrapping="Wrap" AcceptsReturn="True" 

                         VerticalScrollBarVisibility="Auto" 

                         Text="在此输入文字或链接..."/>



             

                <Button x:Name="btnSelectImage" Grid.Row="1"  

                        Content="选择图片文件" Height="30" Width="120" 

                        Click="BtnSelectImage_Click" Visibility="Collapsed"/>

            </Grid>

        </GroupBox>



       

        <GroupBox Grid.Row="1" Header="二维码设置" Margin="0,0,0,10">

            <Grid Margin="10">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>




                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">

                    <TextBlock Text="尺寸(px):" VerticalAlignment="Center" Margin="0,0,5,0"/>

                    <ComboBox x:Name="cmbSize" Width="80" SelectedIndex="1">

                        <ComboBoxItem Content="200"/>

                        <ComboBoxItem Content="300"/>

                        <ComboBoxItem Content="400"/>

                        <ComboBoxItem Content="500"/>

                    </ComboBox>

                </StackPanel>

            </Grid>

        </GroupBox>



     

        <StackPanel Grid.Row="2" Orientation="Horizontal"  

                    HorizontalAlignment="Center" Margin="0,0,0,10">

            <Button x:Name="btnGenerate" Content="生成二维码"  

                    Width="120" Height="35" Margin="0,0,10,0" 

                    Click="BtnGenerate_Click" 

                    Background="#0078D4" Foreground="White" 

                    FontWeight="Bold"/>

            <Button x:Name="btnSave" Content="保存图片"  

                    Width="120" Height="35" 

                    Click="BtnSave_Click" 

                    IsEnabled="False"/>

        </StackPanel>



 

        <Border Grid.Row="3" BorderBrush="LightGray" BorderThickness="1" 

                Background="WhiteSmoke">

            <Grid>


                <TextBlock x:Name="txtPlaceholder"  

                           Text="二维码将显示在这里"  

                           HorizontalAlignment="Center"  

                           VerticalAlignment="Center" 

                           Foreground="Gray" FontSize="16"/>

         

                <Image x:Name="imgQRCode"  

                       HorizontalAlignment="Center"  

                       VerticalAlignment="Center" 

                       Stretch="None"/>

            </Grid>

        </Border>




        <StatusBar Grid.Row="4" Margin="0,5,0,0">

            <TextBlock x:Name="txtStatus" Text="就绪"/>

        </StatusBar>

    </Grid>

</Window> 
